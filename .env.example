# Setup script target selection. AgentV eval target switching is done with
# `agentv eval ... --target legal-document-agent` or another explicit target.
AGENT_TARGET=legal-document-agent
# .agentv/targets.yaml routes the shared `grader` alias through this value.
GRADER_TARGET=openai-grader

# Absolute path to this checkout. Required by CLI-provider targets because
# AgentV runs workspace-backed targets from a temp workspace.
LEGAL_DOCUMENT_EVALS_ROOT=/absolute/path/to/legal-document-agent-evals

# Coding-agent target. The AgentV workspace clones the pinned Harvey LAB task
# directories and becomes the provider cwd, so no project-local workspace path
# is needed here.
CODEX_EXECUTABLE=codex-eng
CODEX_MODEL=gpt-5.5
CODEX_REASONING_EFFORT=low
CODEX_LOG_DIR=.agentv/logs/codex

# Harvey LAB source checkout used only when regenerating eval YAML.
# Example:
#   git clone https://github.com/harveyai/harvey-labs.git ../harvey-labs
#   git -C ../harvey-labs checkout 38936c4f07aa20c84b79abff7b4ad82d1f5902a9
HARVEY_LABS_REPO_PATH=../harvey-labs
HARVEY_LABS_COMMIT=38936c4f07aa20c84b79abff7b4ad82d1f5902a9

# AgentV-native, Irys-inspired document-intelligence/stateful-swarm target.
# This is the primary provider-flexible document-intelligence skill workflow
# target. It uses an OpenAI-compatible chat-completions endpoint in live mode,
# or deterministic mock mode for offline wrapper-contract checks.
STATEFUL_SWARM_MOCK=false
STATEFUL_SWARM_ARTIFACT_ROOT=.agentv/harness-artifacts/stateful-swarm
DOCUMENT_INTELLIGENCE_SKILL_PATH=skills/document-intelligence/SKILL.md
# Default is sized to include the current canonical Harvey subset in full.
# If lowered for smaller-context models, the wrapper excerpts every source
# document fairly instead of sending only the first alphabetic slice.
STATEFUL_SWARM_MAX_DOC_CHARS=500000
STATEFUL_SWARM_TIMEOUT_SECONDS=600
STATEFUL_SWARM_TEMPERATURE=0.1

# Optional exact upstream Irys/stateful-swarms target. This is NOT the primary
# provider-flexible path. Current inspected upstream `irys run` is Gemini/Google-
# backed (src/runner.py and src/cli.py instantiate GeminiCaller).
# Example:
#   git clone https://github.com/dl1683/irys-stateful-swarms.git ../irys-stateful-swarms
#   IRYS_STATEFUL_SWARMS_REPO_PATH=../irys-stateful-swarms
IRYS_STATEFUL_SWARMS_REPO_PATH=../irys-stateful-swarms
# IRYS_EXECUTABLE=irys
# UV_EXECUTABLE=uv
GEMINI_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_KEYS=
SWARM_WORKER_MODEL=gemini-3.1-flash-lite
SWARM_SYNTHESIS_MODEL=gemini-3.5-flash
SWARM_REVIEWER_MODEL=gemini-3.5-flash
IRYS_AGENTV_ARTIFACT_ROOT=.agentv/harness-artifacts/irys-upstream
IRYS_TIMEOUT_SECONDS=7200
IRYS_SCORE_AFTER_RUN=false
IRYS_JUDGE_MODEL=gemini-3.1-flash-lite
IRYS_SCORE_TASK_CONCURRENCY=1
IRYS_SCORE_CRITERIA_CONCURRENCY=4

# AgentV grader target and stateful-swarm live provider. Use OpenAI-compatible
# env directly, or Azure settings for azure-grader. OPENAI_BASE_URL is optional
# for the default OpenAI endpoint and useful for compatible gateways.
OPENAI_MODEL=gpt-5.5
OPENAI_BASE_URL=
OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_RESPONSES_BASE_URL=https://<resource>.openai.azure.com/openai/v1
# AZURE_OPENAI_API_KEY=
# AZURE_DEPLOYMENT_NAME=
# AZURE_OPENAI_API_VERSION=v1
